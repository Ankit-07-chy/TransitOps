# PostgreSQL connection.
# Option A — local host PostgreSQL (what this project is set up to use):
DATABASE_URL="postgresql://transitops:transitops@localhost:5432/transitops_db"
# Option B — Docker Postgres from the included docker-compose.yml (host port 5433):
# DATABASE_URL="postgresql://transitops:transitops@localhost:5433/transitops_db"

# JWT
JWT_SECRET="change-this-in-production-super-secret-key"
JWT_EXPIRES_IN="8h"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"
